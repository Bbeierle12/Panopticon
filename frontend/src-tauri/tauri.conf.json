{
  "productName": "NetSec",
  "version": "0.1.0",
  "identifier": "com.netsec.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://127.0.0.1:5173",
    "beforeDevCommand": "vite --host 127.0.0.1 --port 5173",
    "beforeBuildCommand": "vite build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "NetSec Security Platform",
        "width": 1400,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false
      }
    ],
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true,
      "tooltip": "NetSec Security Platform"
    },
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://127.0.0.1:8420 ws://127.0.0.1:8420; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://cdn.tailwindcss.com; font-src 'self' data:"
    }
  },
  "plugins": {}
}
